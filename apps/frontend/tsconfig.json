{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "types": ["node"],
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "paths": {
      "~/*": ["./src/*"],
      "@/*": ["./src/*"],
      "#app": ["./.nuxt/types/app"],
      "@ew/shared": ["../../libs/shared/src/index.ts"]
    },
    "skipLibCheck": true
  },
  "include": [
    ".nuxt/nuxt.d.ts",
    ".nuxt/types/app.d.ts",
    "src/**/*",
    "../../libs/shared/src/**/*"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.js",
    "src/**/*.spec.jsx",
    "src/**/*.test.js",
    "src/**/*.test.jsx",
    "node_modules",
    "../../apps/backend/**/*",
    "../../libs/database/**/*"
  ],
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}
